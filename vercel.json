{
  "version": 2,

  "builds": [
    {
      "src": "api/play.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "src": "/api/play",
      "dest": "/api/play.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
